// Copy this file to secrets.h (same folder) and fill in real values.
// secrets.h is gitignored — it never gets committed.
#pragma once

// Internet-side network (home / phone hotspot — assume venue WiFi is hostile).
// The paddle does NOT use these; it joins the station's own AP.
#define WIFI_SSID "your-network-name"
#define WIFI_PASS "your-network-password"

// Backend voice endpoint (B7) — device token in the query string.
// Until /api/voice is deployed, any https placeholder keeps the build valid.
#define VOICE_ENDPOINT_URL "https://janelletam-dev--racketcoach-backend.modal.run/api/voice?key=REPLACE_ME"

// Session uploads (end-of-round POST). Omit BACKEND_URL entirely to disable
// uploads — the local game runs unaffected.
#define BACKEND_URL "https://janelletam-dev--racketcoach-backend.modal.run"
#define STATION_PAIRING_CODE "ACE123"        // player 1's claimed pairing code
// #define STATION_PAIRING_CODE_P2 "XYZ789"  // optional: player 2's code
