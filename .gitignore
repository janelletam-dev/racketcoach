# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# Wi-Fi credentials for the board (real values live only on your machine).
# Covers any depth so it still catches secrets.h if an IDE relocates the
# sketch into its own subfolder (e.g. firmware/sketch/secrets.h).
firmware/**/secrets.h

# local SQLite database (created by db:migrate/db:seed). Do not commit.
racketcoach.db
racketcoach.db-shm
racketcoach.db-wal

# python bytecode from modal_app.py
__pycache__/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
