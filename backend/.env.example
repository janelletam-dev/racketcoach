# --- RacketCoach backend (Hono API, deployed on Modal) ---
# Local dev: copy this file to `.env` (it is loaded automatically), then set
# AUTH_SECRET. On Modal these come from the `racketcoach-env` secret.

# Database (libSQL / SQLite). Local dev uses a plain file.
# On Modal, set this to file:/data/racketcoach.db (a mounted Volume).
DATABASE_URL=file:./racketcoach.db

# REQUIRED. Secret used to sign session + magic-link tokens. The server refuses
# to start without it (no insecure fallback). Generate with:
#   openssl rand -base64 33
AUTH_SECRET=replace-me

# Dev-only flag. Enables the /api/auth/demo shortcut (the "Sign in as demo
# user" button). Set to 1 locally; leave it OUT of the Modal secret so the demo
# login returns 403 in production.
ALLOW_DEMO_LOGIN=1

# Dev-only flag. When 1, the Modal container re-seeds demo data on boot. Leave
# it OUT of the Modal secret so a restart never wipes/rewrites the prod DB.
# (Locally you seed with `npm run db:seed` directly; this flag only affects the
# Modal boot path.)
# SEED_DEMO=1

# Port the API listens on (local dev).
PORT=3001

# Where the frontend lives (used for magic-link redirects back to the UI).
FRONTEND_URL=http://localhost:3000

# This backend's own public URL (used to build the magic-link verify URL).
# On Modal this is your https://<workspace>--racketcoach-backend.modal.run URL.
PUBLIC_BACKEND_URL=http://localhost:3001

# Optional: production magic-link email via Resend.
# If unset, the sign-in link is printed to the backend console instead.
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=RacketCoach <onboarding@resend.dev>

# --- Analysis pipeline (B3). Both optional; without them raw uploads resolve
# to analysisStatus "failed" and the session still renders. ---
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# LINKUP_API_KEY=xxxxxxxx
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Voice coach endpoint (B7). Both optional; without them POST /api/voice
# returns 503 and the devices just log it. VOICE_DEVICE_TOKEN is the shared
# token the devices carry in the URL query (secrets.h VOICE_ENDPOINT_URL). The
# voice id is shared with scripts/generate-cues.ts so the instant cue clips and
# the thinking coach are audibly the same person. ---
# ELEVENLABS_API_KEY=xxxxxxxx
# VOICE_DEVICE_TOKEN=$(openssl rand -hex 16)
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# ELEVENLABS_TTS_MODEL=eleven_flash_v2_5
# Web "Ask your coach" TTS (POST /api/coach/speak selects per request):
# ELEVENLABS_VOICE_ID_MALE=xxxxxxxx
# ELEVENLABS_VOICE_ID_FEMALE=xxxxxxxx
