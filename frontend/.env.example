# --- RacketCoach frontend (Next.js UI) ---

# The backend API base URL. Server-side only (the browser never calls it).
# Local dev: the Hono backend. Prod: your Modal URL.
BACKEND_URL=http://localhost:3001

# Public base URL of this frontend, used to build the pairing QR code and
# auth redirects. Baked in at build time.
NEXT_PUBLIC_APP_URL=http://localhost:3000
